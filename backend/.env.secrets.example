# ────────────────────────────────────────────────────────────
# Humming V2 — Secrets template
# ────────────────────────────────────────────────────────────
# 사용법:
#   1. 이 파일을 .env.secrets 로 복사 (git ignore 됨)
#   2. 각 항목 값 채워넣기
#   3. 전부 채워지면 "토큰 다 준비됐어" 라고 알려주기
#   4. 자동화 스크립트가 Fly secrets 일괄 등록 + Cloudflare/Vercel/Supabase 셋업 진행
#
# 절대 git commit 금지. .env.secrets 가 .gitignore 에 있는지 확인.
# ────────────────────────────────────────────────────────────

# ─── 1. Cloudflare (R2 + DNS) ───
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=             # hum-track.com 의 Zone ID (도메인 페이지 우측에 표시)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=humming-vocals
R2_ENDPOINT=                    # https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# ─── 2. Vercel (랜딩) ───
VERCEL_TOKEN=                   # vercel.com/account/tokens
VERCEL_TEAM_ID=                 # 개인 계정이면 비워두기

# ─── 3. Fly.io (API 서버) ───
FLY_API_TOKEN=                  # fly.io/user/personal_access_tokens

# ─── 4. Supabase (Auth + DB) ───
SUPABASE_URL=                   # https://<ref>.supabase.co
SUPABASE_PROJECT_REF=           # <ref> 부분만 (예: abcdefgh)
SUPABASE_SERVICE_ROLE_KEY=      # Settings → API → service_role (절대 노출 금지)
SUPABASE_JWT_SECRET=            # Settings → API → JWT Settings

# ─── 5. Sentry (에러 추적) ───
SENTRY_AUTH_TOKEN=              # sentry.io/settings/account/api/auth-tokens/
SENTRY_DSN_SERVER=              # humming-server 프로젝트 DSN
SENTRY_DSN_MOBILE=              # humming-mobile 프로젝트 DSN

# ─── 6. PostHog (행동 분석) ───
POSTHOG_PERSONAL_API_KEY=       # 프로젝트 생성용
POSTHOG_PROJECT_API_KEY=        # 모바일/서버에서 이벤트 전송용
POSTHOG_HOST=https://us.posthog.com

# ─── 7. UptimeRobot ───
UPTIMEROBOT_API_KEY=            # 메인 API 키

# ─── 8. App Store Connect (IAP, post-MVP) ───
APPLE_BUNDLE_ID=com.humming.humming
APPLE_SHARED_SECRET=
APPLE_KEY_ID=                   # App Store Server API key (.p8 다운로드 후 Key ID)
APPLE_ISSUER_ID=
APPLE_PRIVATE_KEY_PATH=         # .p8 파일 경로 (절대 git X)

# ─── 9. Play Console (IAP, post-MVP) ───
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_PATH=  # JSON 파일 경로
GOOGLE_PLAY_PUBSUB_TOPIC=projects/<gcp-project>/topics/humming-rtdn

# ─── 10. 도메인 ───
DOMAIN=hum-track.com
API_DOMAIN=api.hum-track.com
LANDING_DOMAIN=hum-track.com
