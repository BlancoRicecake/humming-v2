backend/__pycache__/
backend/app/__pycache__/
backend/*.pyc
backend/*.wav
backend/*.mid

frontend/node_modules/
frontend/dist/

# caches / runtime debug artifacts
backend/.pytest_cache/
backend/_debug_uploads/
backend/**/__pycache__/
*.pyc

# bundled FluidSynth: keep the extracted win64 binary for offline render,
# drop the redundant archive
backend/bin/fluidsynth.zip

# personal local Claude Code settings (agents are kept, local settings are not)
.claude/settings.local.json

.DS_Store
.vscode/
.idea/

# regenerated by backend/diagnose.py — do not commit live dump
docs/experiments/keyassist_diag.txt

# Local secrets (never commit)
backend/.env.secrets
.env.secrets
.env.local

# Apple Sign in with Apple private keys (NEVER commit)
*.p8
backend/secrets/

# Ruby/Bundler/fastlane cache (mobile/ios/)
mobile/ios/.bundle/
mobile/ios/.bundle-user/
mobile/ios/vendor/
mobile/ios/fastlane/report.xml
mobile/ios/fastlane/Preview.html
mobile/ios/fastlane/screenshots/**/*.png
mobile/ios/fastlane/test_output

# Fastlane (mobile/)
mobile/fastlane/report.xml
mobile/fastlane/Preview.html
mobile/fastlane/test_output
mobile/fastlane/screenshots-staging/
mobile/fastlane/**/.DS_Store

# Backend secrets (verbose form)
backend/secrets/*.p8
backend/secrets/*.json
backend/secrets/*.plist

# iOS Google Sign In — bundle id 만 들어있어 강한 secret 은 아니지만
# 사용자 지시로 git out-of-tree 유지. 빌드 시 backend/secrets 에서 복사.
mobile/ios/Runner/GoogleService-Info.plist

# Claude Code 에이전트 worktree 자동 생성 디렉터리 — 세션마다 일회성
.claude/worktrees/

# Flutter 가 flutter pub get / flutter run 시 자동 재생성하는 plugin registrant —
# 머신/플랫폼 별로 달라져 매번 diff 가 생긴다.
mobile/linux/flutter/generated_plugin_registrant.cc
mobile/linux/flutter/generated_plugin_registrant.h
mobile/linux/flutter/generated_plugins.cmake
mobile/windows/flutter/generated_plugin_registrant.cc
mobile/windows/flutter/generated_plugin_registrant.h
mobile/windows/flutter/generated_plugins.cmake
mobile/macos/Flutter/GeneratedPluginRegistrant.swift

# CocoaPods lockfile 은 iOS 빌드 환경/머신 별로 자주 갱신되어 diff 가 끼므로
# 의도적으로 untracked (이미 main 에 한 번 커밋되어 있더라도 향후 변경은 무시).
mobile/ios/Podfile.lock
